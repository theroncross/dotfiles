{
  // A E S T H E T I C
  "diagnostic.errorSign": "✘",
  "diagnostic.warningSign": "⚠",
  "diagnostic.infoSign": "ⓘ",

  // worthless sources when language-server is present
  "coc.source.buffer.enable": false,
  "coc.source.file.enable": false,
  "coc.source.around.enable": false,

  // exporer
  "explorer.width": 30,
  "explorer.icon.enableNerdfont": false,
  "explorer.previewAction.onHover": false,
  "explorer.keyMappings.global": {
    "<cr>": ["expandable?", "expand", "open"],
    "v": "open:vsplit"
  },

  // coc-actions config
  "coc-actions.hideCursor": false,

  // Linting
  "eslint.quiet": true,
  "eslint.autoFixOnSave": true,
  "prettier.eslintIntegration": true,

  // NPM
  "npm.binPath": "npm",

  // YAML
  "yaml.format.enable": true,
  "yaml.format.printWidth": 80,
  "yaml.format.proseWrap": "always",

  // Rust
  "rust-client.updateOnStartup": true
}
