exe s:l
normal! zt
1
normal! 0
lcd ~/webapp
wincmd w
argglobal
if bufexists("~/webapp/translations/fr-ca.yaml") | buffer ~/webapp/translations/fr-ca.yaml | else | edit ~/webapp/translations/fr-ca.yaml | endif
